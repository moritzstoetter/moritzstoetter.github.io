---
import CaseStudyList from "../../components/content/case-studies/CaseStudyList.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import Base from "../../layouts/Base.astro";

const t = useTranslations(getLangFromUrl(Astro.url));

export async function getStaticPaths() {
  return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}
---

<Base title={t("meta.caseStudies.title")} description={t("meta.caseStudies.description")}>
  <div class="pb-16">
    <h1 class="section-title">{t("caseStudies.title")}</h1>
    <CaseStudyList />
  </div>
</Base>
