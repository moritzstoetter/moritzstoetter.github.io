---
import Expertise from "../../../components/pages/Expertise.astro";
import { pick } from "../../../i18n/utils";
import Base from "../../../layouts/Base.astro";

import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("expertise");
  return pages.flatMap((page) => [
    { params: { lang: "de", slug: page.id } },
    { params: { lang: "en", slug: page.id } },
  ]);
}

const { slug } = Astro.params;
const lang = Astro.params.lang as "de" | "en";

const expertise = (await getCollection("expertise")).find(
  (s) => s.id === slug,
)?.data;
const title = expertise ? pick(expertise.title, lang) : undefined;
const description = expertise ? pick(expertise.description, lang) : undefined;
---

<Base title={title} description={description}>
  <Expertise lang={lang} slug={slug} />
</Base>
