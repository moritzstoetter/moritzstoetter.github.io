---
import { getCollection } from "astro:content";
import Hero from "../../components/Hero.astro";
import TestimonialSlider from "../../components/ui/TestimonialSlider.astro";
import ExpertiseList from "../../components/business/ExpertiseList.astro";
import IndustryList from "../../components/business/IndustryList.astro";
import CaseStudyList from "../../components/business/CaseStudyList.astro";
import InsightList from "../../components/business/InsightList.astro";
import ContactForm from "../../components/ui/ContactForm.astro";
import Divider from "../../components/ui/Divider.astro";
import { getLangFromUrl, pick, useTranslations } from "../../i18n/utils";
import Base from "../../layouts/Base.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const langTestimonials = [...(await getCollection("testimonials"))].reverse();

// ItemList structured data for the "Our Focus" section: names the domains we
// target so search engines can connect the brand entity to them. Mirrors the
// visible cards; order follows the collection.
const industries = await getCollection("industries");
const focusSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: t("home.industries.title"),
  itemListElement: industries.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: pick(item.data.title, lang),
    description: pick(item.data.description, lang),
  })),
};

// Single source of truth for the home page's vertical rhythm. Every section
// uses the same symmetric padding and the parent adds no gap, so the whitespace
// between any two sections — divider centred in it — is uniform.
const sectionY = "py-12 md:py-20";

export async function getStaticPaths() {
  return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}
---

<Base description={t("meta.home.description")} jsonLd={focusSchema}>
  {/* Uniform vertical rhythm: each section carries the same symmetric `sectionY`
      padding and the parent adds no gap, so every section boundary — with the
      divider centred in it — is one `sectionY` from each side. */}
  <div class="flex flex-col">
    {/* Hero: full-bleed band directly under the navbar bar. The divider that
        follows has no padding above it, so it lands flush on the hero's lower
        edge. */}
    <Hero />
    <Divider />
    <section
      id="content"
      class:list={["scroll-mt-28 [&>h1:first-child]:mt-0", sectionY]}
    >
      <h1>{t("home.expertise.title")}</h1>
      <ExpertiseList />
    </section>
    <Divider />
    <section
      aria-labelledby="focus-heading"
      class:list={["[&>h1:first-child]:mt-0", sectionY]}
    >
      <h1 id="focus-heading">{t("home.industries.title")}</h1>
      <IndustryList />
    </section>
    <Divider />
    <section class:list={["[&>h1:first-child]:mt-0", sectionY]}>
      <h1>{t("home.expertise.testimonials")}</h1>
      <TestimonialSlider testimonials={langTestimonials} />
    </section>
    <Divider />
    <section class:list={["[&>h1:first-child]:mt-0", sectionY]}>
      <h1>{t("caseStudies.title")}</h1>
      <CaseStudyList limit={2} />
      <div class="mt-8 text-right">
        <a class="focused-link text-lg" href={`/${lang}/case-studies/`}>
          {t("common.seeAll")} →
        </a>
      </div>
    </section>
    <Divider />
    <section class:list={["[&>h1:first-child]:mt-0", sectionY]}>
      <h1>{t("insights.title")}</h1>
      <InsightList limit={2} />
      <div class="mt-8 text-right">
        <a class="focused-link text-lg" href={`/${lang}/insights/`}>
          {t("common.seeAll")} →
        </a>
      </div>
    </section>
    <Divider />
    <section class:list={["[&>h1:first-child]:mt-0", sectionY]}>
      <h1>{t("contact.title")}</h1>
      <ContactForm />
    </section>
  </div>
</Base>

<style>
  /* Each home section fades + rises in as it enters, holds while centred, then
     fades + rises away as it exits the top. Pure CSS scroll-driven animation.
     Gated behind @supports because the end state is invisible — browsers
     without scroll-timeline must NOT apply it (they'd hide everything); they
     just show the sections normally. Reduced-motion users skip it too. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      section {
        animation: section-scroll linear both;
        animation-timeline: view();
      }

      @keyframes section-scroll {
        0% {
          opacity: 0;
          transform: translateY(4rem) scale(0.94);
        }
        30%,
        70% {
          opacity: 1;
          transform: none;
        }
        100% {
          opacity: 0;
          transform: translateY(-4rem) scale(0.94);
        }
      }
    }
  }
</style>
