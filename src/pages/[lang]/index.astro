---
import { getCollection } from "astro:content";
import ExpertisePreview from "../../components/business/ExpertisePreview.astro";
import Hero from "../../components/Hero.astro";
import TestimonialSlider from "../../components/ui/TestimonialSlider.astro";
import {
  getLangFromUrl,
  idIsOfLanguage,
  useTranslations,
} from "../../i18n/utils";
import Base from "../../layouts/Base.astro";

const expertise = await getCollection("expertise");
const testimonials = await getCollection("testimonials");

const lang = getLangFromUrl(Astro.url);

const langExpertise = expertise.filter((s) => idIsOfLanguage(s.id, lang));
const langTestimonials = testimonials.filter((t) => idIsOfLanguage(t.id, lang));

const t = useTranslations(lang);

export async function getStaticPaths() {
  return [
    {
      params: {
        lang: "de",
      },
    },
    {
      params: {
        lang: "en",
      },
    },
  ];
}
---

<Base>
  <div class="flex flex-col gap-16 mx-4 md:gap-24 lg:md-0">
    <Hero />
    <section>
      <h1>{t("home.expertise.title")}</h1>
      <div class="flex flex-col gap-16">
        {
          langExpertise?.map((item) => (
            <ExpertisePreview expertise={item.data} />
          ))
        }
      </div>
    </section>
    <section class="mb-16 md:mb-24">
      <h1>{t("home.expertise.testimonials")}</h1>
      <TestimonialSlider testimonials={langTestimonials} />
    </section>
  </div>
</Base>
