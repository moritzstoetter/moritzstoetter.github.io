---
import Box from "../../components/ui/Box.astro";
import Grid from "../../components/ui/Grid.astro";
import Base from "../../layouts/Base.astro";
---

<Base title="Impressum" description="Impressum und rechtliche Informationen zu modern embedded.">
  <section class="flex flex-col gap-8 pb-8" id="imprint">
    <h1 class="section-title">Impressum</h1>
    <h2 class="text-center">Angaben gemäß § 5 DDG</h2>
    <Grid cols={2} class="pb-8">
      <Box padded>
        <div class="flex flex-col gap-4">
          <h3 class="text-primaryLight dark:text-primaryDark">Kontakt</h3>
          <p>
            Moritz Stötter<br />
            Softwareentwickler
          </p>
          <p>
            Krottenkopfstr. 1<br />
            81377 München
          </p>
          Deutschland
        </div>
        <p>
          Tel: +49 (0)151 2304 8794<br />
          E-Mail: info@modernembedded.tech
        </p>
      </Box>
      <Box padded>
        <div class="flex flex-col gap-4">
          <h3 class="text-primaryLight dark:text-primaryDark">
            Berufshaftpflichtversicherung
          </h3>
          <p>
            exali AG<br />
            Franz-Kobinger-Str. 9<br />
            86157 Augsburg<br />
            Deutschland
          </p>
        </div>
      </Box>
      <Box padded>
        <div class="flex flex-col gap-4">
          <h3 class="text-primaryLight dark:text-primaryDark">Rechtliches</h3>
          <p>
            Wir sind nicht bereit oder verpflichtet an Streitbeilegungsverfahren
            vor einer Verbraucherschlichtungsstelle teilzunehmen.
          </p>
        </div>
      </Box>
    </Grid>
  </section>
</Base>
