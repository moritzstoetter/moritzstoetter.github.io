---
import { Image } from "astro:assets";
import type { Testimonial } from "../content.config";
import { getLangFromUrl, pick } from "../i18n/utils";

// The bare testimonial content (avatar, name, subheading, quote) with no surface
// of its own. `Testimonial` wraps this in a Box; the slider renders it directly
// inside one shared, static box so only the content moves on swipe.
interface Props {
  testimonial: Testimonial;
  variant?: "slider" | "caseStudy";
}

const { testimonial, variant = "slider" } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Size variants. Keep full class strings literal so Tailwind can detect them.
const styles = {
  slider: {
    // Spread the content evenly down the shared slider box (sized to the
    // tallest slide), so the top, middle and bottom spacing read about equal.
    // A small min-gap keeps the blocks apart when a box is short.
    justify: "justify-evenly",
    gap: "gap-4",
    image: "w-36 h-36",
    name: "text-2xl sm:text-2xl lg:text-3xl",
    subheading: "text-lg sm:text-xl lg:text-2xl",
    quote: "text-lg sm:text-xl lg:text-2xl",
  },
  caseStudy: {
    // Top-aligned so avatars line up across side-by-side case-study cards.
    justify: "justify-start",
    gap: "gap-4",
    image: "w-16 h-16",
    name: "font-medium",
    subheading: "text-sm",
    quote: "",
  },
}[variant];
---

<div class:list={["flex flex-col h-full", styles.justify, styles.gap]}>
  <div class="flex flex-col items-center gap-2 text-center">
    <Image
      src={testimonial.image}
      alt={testimonial.name}
      class:list={["grow-0 shrink-0 object-cover rounded-full", styles.image]}
    />
    <p class={styles.name}>{testimonial.name}</p>
    <p class:list={["text-textLight/50 dark:text-textDark/50", styles.subheading]}>
      {testimonial.subheading}
    </p>
  </div>
  <p class:list={["italic text-center", styles.quote]}>
    "{pick(testimonial.quote, lang)}"
  </p>
</div>
