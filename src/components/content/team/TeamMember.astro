---
import type { TeamMember } from "../../../content.config";
import { getLangFromUrl, pick } from "../../../i18n/utils";
import SplitBox from "../../ui/SplitBox.astro";

const member: TeamMember = Astro.props.member;
const lang = getLangFromUrl(Astro.url);
---

<SplitBox
  image={member.image}
  imageAlt={member.name}
  title={member.name}
  subtitle={member.subtitle ? pick(member.subtitle, lang) : undefined}
  description={pick(member.description, lang)}
/>
