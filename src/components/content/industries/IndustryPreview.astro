---
import type { Industry } from "../../../content.config";
import { getLangFromUrl, pick } from "../../../i18n/utils";
import Box from "../../ui/Box.astro";

// A single industry card: a centred, stacked line-icon + name + one-liner on a
// Box surface. Non-linked (there are no per-industry detail pages). The icon is
// an inline SVG tinted via `currentColor`, so it follows the accent colour and
// adapts to light/dark mode.
interface Props {
  industry: Industry;
  // Heading level for the industry name. Defaults to h2; the home page passes
  // h3 so cards sit under the section's h2.
  titleAs?: "h1" | "h2" | "h3" | "h4";
}

const { industry, titleAs = "h2" } = Astro.props;
const Heading = titleAs;
const lang = getLangFromUrl(Astro.url);

// Line icons live as raw SVG alongside the collection, in
// src/content/industries/assets/<icon>.svg. Eagerly loaded so we can look one
// up by name at build time.
const icons = import.meta.glob("../../../content/industries/assets/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

const iconSvg = icons[`../../../content/industries/assets/${industry.icon}.svg`];
if (!iconSvg) {
  throw new Error(
    `Industry "${industry.slug}" references missing icon "${industry.icon}" (src/content/industries/assets/${industry.icon}.svg)`,
  );
}
---

<Box padded customClass="h-full">
  <div class="flex h-full flex-col items-center justify-center gap-4 text-center">
    <div
      class="h-14 w-14 text-textLight dark:text-textDark [&>svg]:h-full [&>svg]:w-full"
      aria-hidden="true"
      set:html={iconSvg}
    />
    <Heading class="text-xl text-textLight lg:text-2xl dark:text-textDark">
      {pick(industry.title, lang)}
    </Heading>
    <p class="text-base text-textLight/60 dark:text-textDark/60">
      {pick(industry.description, lang)}
    </p>
  </div>
</Box>
