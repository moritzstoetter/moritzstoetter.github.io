---
import { getCollection } from "astro:content";
import Grid from "../../ui/Grid.astro";
import IndustryPreview from "./IndustryPreview.astro";

// Responsive grid of industry cards (3-up desktop, 2-up tablet, 1-up mobile).
// `limit` clips to the first N (omit to show all). Order follows the numeric
// filename prefix of each entry in src/content/industries.
interface Props {
  limit?: number;
  // Heading level for each card title, forwarded to the previews. Defaults to
  // h2; the home page passes h3.
  titleAs?: "h1" | "h2" | "h3" | "h4";
}
const { limit, titleAs = "h2" }: Props = Astro.props;

const all = await getCollection("industries");
const items = limit ? all.slice(0, limit) : all;
---

<Grid cols={3} breakpoint="md" gap={8} as="ul" class="list-none p-0">
  {
    items.map((item) => (
      <li class="h-full">
        <IndustryPreview industry={item.data} titleAs={titleAs} />
      </li>
    ))
  }
</Grid>
