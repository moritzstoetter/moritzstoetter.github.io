---
import { getLangFromUrl } from "../../../i18n/utils";
import SplitBox from "../../ui/SplitBox.astro";

interface Props {
  insight: any;
  // When true (default) the box links to the insight; the insight page's own
  // header passes false so it isn't a self-link.
  linked?: boolean;
  // Mirror the image/text arrangement (image right, text left).
  swap?: boolean;
  // Heading level for the card title. Defaults to h2 (listing pages); the home
  // page passes h3 so cards sit under the section's h2.
  titleAs?: "h1" | "h2" | "h3" | "h4";
}

const { insight, linked = true, swap = false, titleAs = "h2" } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const slug = insight.id.split("/")[1];
---

<SplitBox
  image={insight.data.image}
  imageAlt={insight.data.imageAlt}
  title={insight.data.title}
  subtitle={insight.data.subtitle}
  description={insight.data.description}
  href={linked ? `/${lang}/insights/${slug}` : undefined}
  swap={swap}
  titleAs={titleAs}
/>
