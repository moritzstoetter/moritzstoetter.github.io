---
import type { Expertise } from "../../../content.config";
import { getLangFromUrl, pick } from "../../../i18n/utils";
import SplitBox from "../../ui/SplitBox.astro";

interface Props {
  expertise: Expertise;
  // When true (default) the box links to the expertise subpage; the subpage's
  // own header passes false so it isn't a self-link.
  linked?: boolean;
  // Mirror the image/text arrangement (image right, text left).
  swap?: boolean;
  // Heading level for the card title. Defaults to h2 (listing pages); the home
  // page passes h3 so cards sit under the section's h2.
  titleAs?: "h1" | "h2" | "h3" | "h4";
}

const { expertise, linked = true, swap = false, titleAs = "h2" } = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<SplitBox
  image={expertise.image}
  imageAlt={pick(expertise.title, lang)}
  title={pick(expertise.title, lang)}
  description={pick(expertise.description, lang)}
  href={linked ? `/${lang}/expertise/${expertise.slug}` : undefined}
  swap={swap}
  titleAs={titleAs}
/>
