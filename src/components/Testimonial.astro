---
import type { Testimonial } from "../content.config";
import Box from "./ui/Box.astro";
import TestimonialContent from "./TestimonialContent.astro";

// A testimonial in its own Box surface (used on case-study pages). The slider
// uses TestimonialContent directly inside one shared static box instead.
interface Props {
  testimonial: Testimonial;
  variant?: "slider" | "caseStudy";
}

const { testimonial, variant = "slider" } = Astro.props;
---

<Box padded customClass="h-full">
  <TestimonialContent testimonial={testimonial} variant={variant} />
</Box>
