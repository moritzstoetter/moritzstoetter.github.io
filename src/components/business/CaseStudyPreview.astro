---
import type { CaseStudy } from "../../content.config";
import { getLangFromUrl, pick } from "../../i18n/utils";
import SplitBox from "../ui/SplitBox.astro";

interface Props {
  caseStudy: CaseStudy;
  // When true (default) the box links to the case-study subpage; the subpage's
  // own header passes false so it isn't a self-link.
  linked?: boolean;
  // Mirror the image/text arrangement (image right, text left).
  swap?: boolean;
}

const { caseStudy, linked = true, swap = false } = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<SplitBox
  image={caseStudy.image}
  imageAlt={pick(caseStudy.title, lang)}
  title={pick(caseStudy.title, lang)}
  subtitle={caseStudy.client}
  description={pick(caseStudy.description, lang)}
  href={linked ? `/${lang}/case-studies/${caseStudy.slug}` : undefined}
  swap={swap}
/>
