---
import type { Tech } from "../../content.config";
import Box from "../ui/Box.astro";
import IconText from "../ui/IconText.astro";

const tech: Tech = Astro.props.technology;
---

<Box padded>
  <IconText
    size="sm"
    title={tech.name}
    description={tech.description}
    icon={tech.image || undefined}
    iconAlt={tech.name}
  />
</Box>
