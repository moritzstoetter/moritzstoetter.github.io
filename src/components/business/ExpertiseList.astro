---
import { getCollection } from "astro:content";
import ExpertisePreview from "./ExpertisePreview.astro";

// Stacked list of expertise previews. `limit` clips to the first N (omit to
// show all). Shared by the root page and the listing page.
interface Props {
  limit?: number;
}
const { limit }: Props = Astro.props;

const all = await getCollection("expertise");
const items = limit ? all.slice(0, limit) : all;
---

<div class="flex flex-col gap-16">
  {items.map((item) => <ExpertisePreview expertise={item.data} />)}
</div>
