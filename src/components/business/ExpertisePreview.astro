---
import { Image } from "astro:assets";
import type { Expertise } from "../../content.config";
import { getLangFromUrl } from "../../i18n/utils";
import Box from "../ui/Box.astro";

const expertise: Expertise = Astro.props.expertise;

const lang = getLangFromUrl(Astro.url);
---

<Box href={`/${lang}/expertise/${expertise.slug}`}>
  <div class="relative h-80 overflow-hidden rounded-2xl md:h-[28rem]">
    {/* Background Image: full width on mobile; sharp left half + strongly blurred right half on larger screens */}
    <div class="absolute inset-0 flex">
      <Image
        src={expertise.image}
        alt={expertise.title}
        class="object-cover w-full h-full md:w-1/2"
      />
      <Image
        src={expertise.image}
        alt=""
        aria-hidden="true"
        class="hidden h-full w-1/2 scale-110 object-cover blur-3xl md:block"
      />
    </div>

    {/* Content Grid */}
    <div class="relative h-full grid grid-cols-1 md:grid-cols-2">
      <div class="flex flex-col justify-between gap-4 px-8 py-8 bg-white/75 dark:bg-black/75 md:col-start-2">
        <h2 class="text-primaryLight dark:text-primaryDark">{expertise.title}</h2>
        <p>{expertise.description}</p>
      </div>
    </div>
  </div>
</Box>
