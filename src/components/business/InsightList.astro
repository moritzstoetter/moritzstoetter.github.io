---
import { getCollection } from "astro:content";
import { getLangFromUrl, idIsOfLanguage } from "../../i18n/utils";
import InsightPreview from "./InsightPreview.astro";

// Stacked list of insight previews for the current language, ordered by
// filename (descending, so a higher numeric prefix shows first). `limit` clips
// to the first N (omit to show all). Shared by the root page and the /insights
// listing page.
interface Props {
  limit?: number;
}
const { limit }: Props = Astro.props;
const lang = getLangFromUrl(Astro.url);

const all = (await getCollection("insights"))
  .filter((s) => idIsOfLanguage(s.id, lang))
  .sort((a, b) => b.id.localeCompare(a.id));
const items = limit ? all.slice(0, limit) : all;
---

<div class="flex flex-col gap-16">
  {items.map((insight) => <InsightPreview insight={insight} />)}
</div>
