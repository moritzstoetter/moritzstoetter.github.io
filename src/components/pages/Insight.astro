---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { findInsightsByTags } from "../../lib/insights/util";
import InsightPreview from "../business/InsightPreview.astro";

const { slug } = Astro.params;
const lang = getLangFromUrl(Astro.url);

const insights = await getCollection("insights");

const insight = insights.find((s) => s.id === `${lang}/${slug}`);

const rendering = insight ? await render(insight) : undefined;

const relatedInsights = await findInsightsByTags(
  lang,
  insight?.data.tags ?? [],
  slug,
);

const t = useTranslations(lang);
---

{
  !!insight && !!rendering ? (
    <article class="flex flex-col gap-4 px-4 pb-8 mx-4 md:px-0 lg:mx-0">
      <h1>{insight.data.title}</h1>
      <div class="h-96 overflow-hidden">
        <Image
          src={insight.data.image}
          alt={insight.data.imageAlt}
          class="w-full h-[200%] object-cover object-center -translate-y-1/4"
        />
      </div>
      <div class="pb-8 prose dark:prose-dark max-w-none lg:prose-xl">
        <rendering.Content />
      </div>
      <div class="w-full text-right">
        <h6>{insight.data.date.toISOString().slice(0, 10)}</h6>
      </div>
      {relatedInsights?.length > 0 && (
        <>
          <h2>{t("common.relatedInsights")}</h2>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            {relatedInsights.map((insight) => (
              <InsightPreview insight={insight} />
            ))}
          </div>
        </>
      )}
    </article>
  ) : (
    <div>
      <h1>{t("insights.notFound")}</h1>
    </div>
  )
}
