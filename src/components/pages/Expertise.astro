---
import { getCollection } from "astro:content";
import { idIsOfLanguage, useTranslations } from "../../i18n/utils";
import ExpertisePreview from "../business/ExpertisePreview.astro";
import Grid from "../ui/Grid.astro";
import Box from "../ui/Box.astro";
import IconText from "../ui/IconText.astro";
import Technology from "../business/Technology.astro";

const { lang, slug } = Astro.props;

const expertiseEntries = await getCollection("expertise");

const expertise = expertiseEntries.find((s) => s.id === `${lang}/${slug}`)?.data;

const insightEntries = await getCollection("insights");
const caseStudyEntries = await getCollection("case-studies");

// Resolve the explicitly-linked related content by slug, preserving the
// authored order and filtering to the current language.
const relatedInsights = (expertise?.insights ?? []).flatMap((s) => {
  const e = insightEntries.find(
    (i) => idIsOfLanguage(i.id, lang) && i.id.split("/")[1] === s,
  );
  return e ? [e] : [];
});
const relatedCaseStudies = (expertise?.case_studies ?? []).flatMap((s) => {
  const e = caseStudyEntries.find(
    (c) => idIsOfLanguage(c.id, lang) && c.data.slug === s,
  );
  return e ? [e] : [];
});

// Match the "Unsere Expertise" section heading (base h1 styling), incl. its
// generous vertical breathing room (my-8 md:my-16) so each related section is
// clearly set apart (vertical rhythm / whitespace around section headings).
const sectionHeading =
  "my-8 md:my-16 text-center font-bold uppercase text-2xl sm:text-3xl lg:text-4xl";

const t = useTranslations(lang);
---

{
  !!expertise ? (
    <section class="flex flex-col gap-8 py-8" id={expertise.title}>
      <ExpertisePreview expertise={expertise} linked={false} swap />
      <Grid cols={3} gap={8}>
        {expertise.tech.map((technology) => (
          <Technology technology={technology} />
        ))}
      </Grid>
      {relatedCaseStudies.length > 0 && (
        <div class="flex flex-col gap-4">
          <h2 class={sectionHeading}>{t("common.relatedCaseStudies")}</h2>
          <Grid cols={3} gap={4}>
            {relatedCaseStudies.map((caseStudy) => (
              <Box padded href={`/${lang}/case-studies/${caseStudy.data.slug}`} customClass="h-full">
                <IconText
                  size="sm"
                  title={caseStudy.data.title}
                  subtitle={caseStudy.data.client}
                  description={caseStudy.data.description}
                />
              </Box>
            ))}
          </Grid>
        </div>
      )}
      {relatedInsights.length > 0 && (
        <div class="flex flex-col gap-4">
          <h2 class={sectionHeading}>{t("common.relatedInsights")}</h2>
          <Grid cols={3} gap={4}>
            {relatedInsights.map((insight) => (
              <Box padded href={`/${lang}/insights/${insight.id.split("/")[1]}`} customClass="h-full">
                <IconText
                  size="sm"
                  title={insight.data.title}
                  subtitle={insight.data.subtitle}
                />
              </Box>
            ))}
          </Grid>
        </div>
      )}
    </section>
  ) : (
    <div>
      <h1>{t("home.expertise.notFound")}</h1>
    </div>
  )
 }