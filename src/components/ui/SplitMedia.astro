---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import IconText from "./IconText.astro";

// The image + frosted-text split itself, with no surface/rounding of its own —
// the parent clips it. Used inside SplitBox (a Box) and the home masthead card.
interface Props {
  image: ImageMetadata;
  imageAlt?: string;
  title: string;
  subtitle?: string;
  description?: string;
  icon?: ImageMetadata;
  iconAlt?: string;
  // false: image left, text right (default). true: image right, text left.
  swap?: boolean;
  // Height of the split. Defaults to the content-card size; the home masthead
  // passes a taller value so it reads as a hero rather than another card.
  heightClass?: string;
  // Heading level for the title (passed to IconText). Defaults to h2; the home
  // hero passes h1, home cards pass h3.
  titleAs?: "h1" | "h2" | "h3" | "h4";
}

const {
  image,
  imageAlt = "",
  title,
  subtitle,
  description,
  icon,
  iconAlt = "",
  swap = false,
  heightClass = "min-h-80 md:min-h-[28rem]",
  titleAs = "h2",
} = Astro.props;

// Optional action area below the text (e.g. the masthead's CTA button),
// provided via the `cta` slot. Cards leave it empty and render nothing.
const hasCta = Astro.slots.has("cta");

const panelClass =
  "flex flex-col justify-center px-8 py-8 bg-backgroundLight/75 dark:bg-backgroundDarker/60";
---

<div class:list={["relative flex", heightClass]}>
  {/* Background: sharp half + strongly blurred half (md+). The text always
      sits over the blurred half; `swap` only re-orders which side that is. */}
  <div class="absolute inset-0 flex">
    <div
      class:list={["h-full w-full overflow-hidden md:w-1/2", swap && "md:order-2"]}
    >
      <Image src={image} alt={imageAlt} class="h-full w-full object-cover" />
    </div>
    <div
      class:list={[
        "hidden h-full w-1/2 overflow-hidden md:block",
        swap && "md:order-1",
      ]}
    >
      <Image
        src={image}
        alt=""
        aria-hidden="true"
        class="h-full w-full scale-110 object-cover blur-3xl"
      />
    </div>
  </div>

  {/* Frosted panel over the blurred half. As the sole in-flow child of the
      flex root it stretches to the box height — which is `min-h` driven, so the
      box grows to fit text that would otherwise be clipped, while short content
      still centres within the minimum height. */}
  <div class="relative grid w-full grid-cols-1 md:grid-cols-2">
    <div class:list={[panelClass, swap ? "md:col-start-1" : "md:col-start-2"]}>
      <IconText
        title={title}
        subtitle={subtitle}
        description={description}
        icon={icon}
        iconAlt={iconAlt}
        titleAs={titleAs}
      />
    </div>
  </div>

  {/* Optional CTA, pinned to the lower-right corner of the whole box. */}
  {hasCta && (
    <div class="absolute bottom-0 right-0 z-10 p-6 md:p-8">
      <slot name="cta" />
    </div>
  )}
</div>
