---
import type { ImageMetadata } from "astro";
import Box from "./Box.astro";
import SplitMedia from "./SplitMedia.astro";

// A SplitMedia (sharp image + frosted text) wrapped in a Box surface, optionally
// linked. The split content itself lives in SplitMedia so it can be reused
// without a Box (e.g. the home masthead).
interface Props {
  image: ImageMetadata;
  imageAlt?: string;
  title: string;
  subtitle?: string;
  description?: string;
  icon?: ImageMetadata;
  iconAlt?: string;
  href?: string;
  swap?: boolean;
  titleAs?: "h1" | "h2" | "h3" | "h4";
}

const { href, ...media } = Astro.props;
---

<Box href={href}>
  <SplitMedia {...media} />
</Box>
