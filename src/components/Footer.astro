---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Same profiles as the Organization schema's sameAs (rel="me" closes the
// reciprocal identity link). Icons are inline so there is no extra request.
const socials = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/105752649",
    path: "M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z",
  },
  {
    label: "GitHub",
    href: "https://github.com/modernembedded/",
    path: "M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.9 1.2 2 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z",
  },
  {
    label: "GitLab",
    href: "https://gitlab.com/modernembedded/",
    path: "M23.6 9.6 23.6 9.5 20.9 1c-.2-.6-.6-.9-1.1-.9-.5 0-.9.4-1 .9L16.6 9H7.4L5.2 1C5 .4 4.7.1 4.2.1 3.7.1 3.3.4 3.1 1L.4 9.5v.1c-.4 1 .1 2.2 1 2.8l10.1 7.4c.3.2.7.2 1 0l10.1-7.4c.9-.7 1.4-1.8 1-2.8z",
  },
];
---

<div
  class="flex flex-col gap-3 px-6 py-4 border-t-2 border-primaryLight/10 dark:border-neutral-700/40">
  <div class="flex items-center justify-center gap-4">
    <a
      class={`${
        Astro.url.pathname === `/${lang}/imprint`
          ? "text-primaryLight dark:text-primaryDark"
          : ""
      }`}
      href={`/${lang}/imprint`}>{t("footer.imprint")}</a
    >
    <a
      class={`${
        Astro.url.pathname === `/${lang}/privacy`
          ? "text-primaryLight dark:text-primaryDark"
          : ""
      }`}
      href={`/${lang}/privacy`}>{t("footer.privacy")}</a
    >
  </div>
  <div class="flex items-center justify-center gap-5">
    {
      socials.map((s) => (
        <a
          href={s.href}
          rel="me noopener noreferrer"
          target="_blank"
          aria-label={s.label}
          class="text-primaryLight/70 transition-colors hover:text-primaryLight dark:text-neutral-400 dark:hover:text-primaryDark">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-5 w-5"
            aria-hidden="true">
            <path d={s.path} />
          </svg>
        </a>
      ))
    }
  </div>
</div>
