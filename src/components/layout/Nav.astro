---
import BurgerMenu from "../ui/BurgerMenu.astro";
import LanguagePicker from "../ui/LanguagePicker.astro";
import NavList from "./NavList.astro";
import ThemeIcon from "../ui/ThemeIcon.astro";
import { Image } from "astro:assets";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);

// Full-width sticky bar at the top of every page (home included). The bar
// background and bottom border span the viewport; the inner row stays aligned
// to the page's max-w-5xl content column.
const barClass =
  "full-bleed sticky top-0 z-50 border-b bg-white/50 backdrop-blur-md dark:bg-backgroundDarker/80 border-primaryLight/10 dark:border-neutral-700";
---

<div class={barClass}>
  <div class="mx-auto flex w-full max-w-5xl flex-col px-4 py-2 lg:px-0">
    <div class="flex items-center justify-between">
    <a href={`/${lang}/`}>
      <div class="hidden md:block pr-4">
        <div class="block dark:hidden">
          <Image
            width={256}
            height={64}
            src="/logo_light.webp"
            alt="modern embedded"
          />
        </div>
        <div class="hidden dark:block">
          <Image
            width={256}
            height={64}
            src="/logo_dark.webp"
            alt="modern embedded"
          />
        </div>
      </div>
        <div class="block md:hidden">
          <div class="block dark:hidden">
            <Image
              width={64}
              height={64}
              src="/logo_mobile_light.webp"
              alt="modern embedded"
            />
          </div>
          <div class="hidden dark:block">
            <Image
              width={64}
              height={64}
              src="/logo_mobile_dark.webp"
              alt="modern embedded"
            />
          </div>
        </div>
    </a>
    <div class="flex items-center gap-4">
      <div class="hidden md:block">
        <NavList alignment="horizontal" />
      </div>
      <div class="flex item-center md:hidden">
        <BurgerMenu />
      </div>
      <LanguagePicker />
      <ThemeIcon />
    </div>
  </div>
  <div
    id="mobile-menu"
    class="overflow-hidden transition-[height] duration-300 ease-in-out h-0 md:hidden"
  >
    <div class="py-4" id="mobile-menu-content">
      <NavList alignment="vertical" />
    </div>
  </div>
  </div>
</div>

<script>
  let mobileMenuOpen = false;
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuContent = document.getElementById("mobile-menu-content");

  document.addEventListener("toggleMenu", () => {
    mobileMenuOpen = !mobileMenuOpen;
    if (mobileMenu && mobileMenuContent) {
      const contentHeight = mobileMenuContent.getBoundingClientRect().height;

      if (mobileMenuOpen) {
        mobileMenu.style.height = `${contentHeight}px`;
      } else {
        mobileMenu.style.height = "0px";
      }
    }
  });
</script>
