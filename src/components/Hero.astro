---
import hero from "../assets/hero.webp";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import SplitMedia from "./ui/SplitMedia.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

{/* Home hero: a self-contained rounded box, vertically centred in the first
    viewport by the home page's hero section. */}
<div
  id="hero"
  class="overflow-hidden rounded-[39px] border-2 border-primaryLight/10 dark:border-neutral-700"
>
  <SplitMedia
    image={hero}
    imageAlt="hero"
    title={t("home.hero.title")}
    description={t("home.hero.subtitle")}
    heightClass="min-h-[34rem] md:min-h-[40rem] lg:min-h-[44rem]"
    swap
  >
    <a slot="cta" href={`/${lang}/contact`} class="button-primary w-fit">
      {t("home.hero.cta")}
    </a>
  </SplitMedia>
</div>
