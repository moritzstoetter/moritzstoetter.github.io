---
import hero from "../assets/hero.webp";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import SplitMedia from "./ui/SplitMedia.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

{/* Home hero: a full-bleed band spanning the viewport, vertically placed in the
    first viewport by the home page's hero section. Edge-to-edge, so it drops the
    card's rounding/border. */}
<div id="hero" class="full-bleed overflow-hidden">
  <SplitMedia
    image={hero}
    imageAlt="hero"
    title={t("home.hero.title")}
    description={t("home.hero.subtitle")}
    heightClass="min-h-[34rem] md:min-h-[40rem] lg:min-h-[44rem]"
    titleAs="h1"
    swap
  >
    <a slot="cta" href={`/${lang}/contact`} class="button-primary w-fit">
      {t("home.hero.cta")}
    </a>
  </SplitMedia>
</div>
