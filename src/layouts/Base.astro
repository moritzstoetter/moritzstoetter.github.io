---
import { getCollection } from "astro:content";
import Nav from "../components/layout/Nav.astro";
import { getLangFromUrl } from "../i18n/utils";
import "../base.css";
import Footer from "../components/layout/Footer.astro";
import ContactButton from "../components/layout/ContactButton.astro";

const lang = getLangFromUrl(Astro.url);

// Per-page SEO. Every page passes its own title/description; without them a
// page would inherit the site-wide defaults (fine only for the home page).
interface Props {
  title?: string;
  description?: string;
  // Absolute or root-relative path to a social-share image; defaults to the logo.
  image?: string;
  // Deep pages pass a breadcrumb trail ({ name, path }); rendered as a
  // BreadcrumbList. Listing/home pages omit it.
  breadcrumbs?: { name: string; path: string }[];
  // Any extra JSON-LD schema object(s) a page wants to emit (e.g. Person).
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  // og:type — "article" for insights (adds article:* meta), else "website".
  ogType?: "website" | "article";
  // Article metadata, emitted only when ogType === "article".
  article?: { publishedTime: string; modifiedTime?: string; author?: string };
}
const {
  title,
  description,
  image,
  breadcrumbs,
  jsonLd,
  ogType = "website",
  article,
} = Astro.props;

const SITE = "https://modernembedded.tech";
const BRAND = "modern embedded";
const DEFAULT_DESCRIPTION =
  "Cutting edge software development for embedded devices in modern C++.";

// Profiles that represent this same entity elsewhere. Consolidates the brand
// into one Knowledge-Graph node (schema.org sameAs).
const SAME_AS = [
  "https://www.linkedin.com/company/105752649",
  "https://github.com/modernembedded/",
  "https://gitlab.com/modernembedded/",
];

const pageTitle = title
  ? `${title} | ${BRAND}`
  : `${BRAND} — Cutting edge embedded software development`;
const pageDescription = description ?? DEFAULT_DESCRIPTION;

// Canonical + social URLs must reflect the *actual* page, not the home page.
const canonical = new URL(Astro.url.pathname, SITE).href;
// Social scrapers want a real 1200×630 card in a widely-supported raster
// format (PNG/JPG — several don't render WebP), so the default stays PNG.
const ogImage = new URL(image ?? "/logo_og.png", SITE).href;

// hreflang alternates: every route exists in both languages, so we derive the
// counterpart URL by swapping the leading locale segment. x-default points at
// the default locale (de).
const localizedPath = (l: string) =>
  Astro.url.pathname.replace(/^\/(de|en)/, `/${l}`);
const alternates = [
  { hreflang: "de", href: new URL(localizedPath("de"), SITE).href },
  { hreflang: "en", href: new URL(localizedPath("en"), SITE).href },
  { hreflang: "x-default", href: new URL(localizedPath("de"), SITE).href },
];

// --- Structured data (JSON-LD) -------------------------------------------
// Site-wide organization identity, emitted on every page. Reviews carry the
// real testimonial text/author but no ratingValue — we don't collect numeric
// ratings, and inventing them to earn star snippets violates Google's policy.
const testimonials = await getCollection("testimonials");
const reviews = testimonials.map((tt) => ({
  "@type": "Review",
  author: { "@type": "Person", name: tt.data.name },
  reviewBody: tt.data.quote[lang],
}));

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${SITE}/#organization`,
  name: BRAND,
  url: `${SITE}/`,
  logo: `${SITE}/logo_dark.webp`,
  image: `${SITE}/logo_og.png`,
  description: DEFAULT_DESCRIPTION,
  email: "info@modernembedded.tech",
  telephone: "+49-151-23048794",
  founder: {
    "@type": "Person",
    name: "Moritz Stötter",
    jobTitle: "Embedded C++ Specialist",
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Krottenkopfstr. 1",
    postalCode: "81377",
    addressLocality: "München",
    addressCountry: "DE",
  },
  knowsAbout: [
    "Embedded software development",
    "Modern C++",
    "RTOS",
    "Firmware",
    "Bluetooth Low Energy",
    "Wi-Fi",
    "DevOps",
    "Medical device software",
    "Life sciences instrumentation",
    "Scientific instrument firmware",
    "Real-time audio processing",
  ],
  sameAs: SAME_AS,
  review: reviews,
};

const breadcrumbSchema = breadcrumbs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: new URL(b.path, SITE).href,
      })),
    }
  : undefined;

const extraSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [
  organizationSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...extraSchemas,
];

// A "contact us" CTA hovers in the bottom-right corner of every page except
// the contact page itself.
const showContact = !/\/contact\/?$/.test(Astro.url.pathname);

// The home page's hero fills the first viewport, so its main drops the usual
// top padding (the hero section manages its own height instead).
const isHome = /^\/(de|en)\/?$/.test(Astro.url.pathname);
---

<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>

    <!-- Favicons -->
    <!-- SVG favicon with embedded CSS -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PNG fallbacks with media queries -->
    <link rel="icon" href="/favicon-light-16x16.png" sizes="16x16" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-16x16.png" sizes="16x16" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-light-32x32.png" sizes="32x32" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-32x32.png" sizes="32x32" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-light-192x192.png" sizes="192x192" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-192x192.png" sizes="192x192" media="(prefers-color-scheme: dark)" />
    <!-- Apple touch icon (iOS doesn't support media queries) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-dark-180x180.png" />

    <!-- Web app manifest -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={BRAND} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    {
      ogType === "article" && article && (
        <>
          <meta property="article:published_time" content={article.publishedTime} />
          {article.modifiedTime && (
            <meta property="article:modified_time" content={article.modifiedTime} />
          )}
          {article.author && (
            <meta property="article:author" content={article.author} />
          )}
        </>
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />

    <!-- hreflang alternates for the de/en versions of this page -->
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }

    <!-- Structured data (JSON-LD) -->
    {
      schemas.map((s) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
      ))
    }
    <!-- Check for dark mode to avoid light/dark theme blinking -->
    <script is:inline>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="flex flex-col justify-between min-h-screen overflow-x-clip bg-backgroundLight dark:bg-backgroundDarker">
    <div class="relative w-full max-w-5xl lg:mx-auto">
      <Nav />
      <main class:list={["px-4 lg:px-0", !isHome && "pt-4 md:pt-16"]}>
        <slot />
      </main>
    </div>
    <Footer />
    {
      showContact && (
        <div
          id="floating-contact"
          class:list={[
            "fixed bottom-8 right-8 z-50 transition-opacity duration-300",
            // On home the hero is in view on load, so start hidden; the observer
            // below reveals it once the hero scrolls out.
            isHome && "opacity-0 pointer-events-none",
          ]}
        >
          <ContactButton />
        </div>
      )
    }
    {/* Hide the floating contact button while a section that already covers the
        "get in touch" action is in view — the home hero (its in-box CTA) and
        the home contact section (the form itself). Redundant otherwise. */}
    <script>
      const fab = document.getElementById("floating-contact");
      const watched = ["hero", "contact-section"]
        .map((id) => document.getElementById(id))
        .filter((el) => el !== null);
      if (fab && watched.length) {
        const visible = new Set();
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) visible.add(entry.target);
              else visible.delete(entry.target);
            }
            const hide = visible.size > 0;
            fab.classList.toggle("opacity-0", hide);
            fab.classList.toggle("pointer-events-none", hide);
          },
          { threshold: 0 },
        );
        watched.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
