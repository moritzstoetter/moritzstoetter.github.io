---
import Nav from "../components/Nav.astro";
import { getLangFromUrl } from "../i18n/utils";
import "../base.css";
import Footer from "../components/Footer.astro";
import ContactButton from "../components/ContactButton.astro";

const lang = getLangFromUrl(Astro.url);

// A "contact us" CTA hovers in the bottom-right corner of every page except
// the contact page itself.
const showContact = !/\/contact\/?$/.test(Astro.url.pathname);

// The home page's hero fills the first viewport, so its main drops the usual
// top padding (the hero section manages its own height instead).
const isHome = /^\/(de|en)\/?$/.test(Astro.url.pathname);
---

<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Cutting edge software development for embedded devices."
    />
    <meta
      name="keywords"
      content="Freelance, C++, Embedded, RTOS, Software Developer, BLE, Wifi, Firmware, Senior Software Developer, Software Architect"
    />
    <title>modern embedded</title>

    <!-- Favicons -->
    <!-- SVG favicon with embedded CSS -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PNG fallbacks with media queries -->
    <link rel="icon" href="/favicon-light-16x16.png" sizes="16x16" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-16x16.png" sizes="16x16" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-light-32x32.png" sizes="32x32" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-32x32.png" sizes="32x32" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-light-192x192.png" sizes="192x192" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark-192x192.png" sizes="192x192" media="(prefers-color-scheme: dark)" />
    <!-- Apple touch icon (iOS doesn't support media queries) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-dark-180x180.png" />

    <!-- Web app manifest -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://modernembedded.tech/${lang}/`} />
    <meta property="og:title" content="modern embedded - Cutting edge embedded software development" />
    <meta property="og:description" content="Cutting edge software development for embedded devices in modern C++." />
    <meta property="og:image" content="https://modernembedded.tech/logo_dark.png" />
    <meta property="og:site_name" content="modern embedded" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://modernembedded.tech/${lang}/`} />
    <meta property="twitter:title" content="modern embedded - Cutting edge embedded software development" />
    <meta property="twitter:description" content="Cutting edge software development for embedded devices in modern C++." />
    <meta property="twitter:image" content="https://modernembedded.tech/logo_dark.png" />

    <!-- Canonical URL -->
    <link rel="canonical" href={`https://modernembedded.tech/${lang}/`} />
    <!-- Check for dark mode to avoid light/dark theme blinking -->
    <script is:inline>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="flex flex-col justify-between min-h-screen overflow-x-clip bg-backgroundLight dark:bg-backgroundDarker">
    <div class="relative w-full max-w-5xl lg:mx-auto">
      <Nav />
      <main class:list={["px-4 lg:px-0", !isHome && "pt-4 md:pt-16"]}>
        <slot />
      </main>
    </div>
    <Footer />
    {
      showContact && (
        <div
          id="floating-contact"
          class:list={[
            "fixed bottom-8 right-8 z-50 transition-opacity duration-300",
            // On home the hero is in view on load, so start hidden; the observer
            // below reveals it once the hero scrolls out.
            isHome && "opacity-0 pointer-events-none",
          ]}
        >
          <ContactButton />
        </div>
      )
    }
    {/* Hide the floating contact button while the home hero is in view — its
        in-box CTA already covers that action there. */}
    <script>
      const hero = document.getElementById("hero");
      const fab = document.getElementById("floating-contact");
      if (hero && fab) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            const hidden = entry.isIntersecting;
            fab.classList.toggle("opacity-0", hidden);
            fab.classList.toggle("pointer-events-none", hidden);
          },
          { threshold: 0 },
        );
        observer.observe(hero);
      }
    </script>
  </body>
</html>
